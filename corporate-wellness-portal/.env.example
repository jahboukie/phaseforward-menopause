# Corporate Wellness Portal - Environment Configuration
# Copy to .env and update with your values

# Server Configuration
NODE_ENV=development
PORT=8080
DOMAIN=localhost:8080

# Database Configuration (Multi-tenant PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/corporate_wellness
DATABASE_SSL=true
DATABASE_POOL_SIZE=20

# Redis Configuration (Sessions & Caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=86400

# Security Keys (Generate new for production)
JWT_SECRET=your-super-secure-jwt-secret-256-bits-minimum
SESSION_SECRET=your-super-secure-session-secret-256-bits
ENCRYPTION_KEY=your-super-secure-encryption-key-256-bits
TENANT_ENCRYPTION_SALT=your-super-secure-tenant-salt-256-bits

# Dr. Alex AI Integration
DRALEXAI_API_URL=https://dralexai.com/api
DRALEXAI_API_KEY=your-dralexai-enterprise-api-key
DRALEXAI_CLIENT_ID=your-dralexai-client-id
DRALEXAI_CLIENT_SECRET=your-dralexai-client-secret

# SentimentAsAService Integration
SENTIMENT_API_URL=https://sentimentasaservice.com/api
SENTIMENT_API_KEY=your-sentiment-enterprise-api-key
SENTIMENT_CLIENT_ID=your-sentiment-client-id

# Claude AI Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-sonnet-20240229

# Email Configuration (Enterprise notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=corporate-wellness@yourdomain.com
SMTP_PASS=your-smtp-password

# Enterprise SSO Configuration
SAML_ENABLED=false
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=

LDAP_ENABLED=false
LDAP_URL=ldap://your-ldap-server:389
LDAP_BIND_DN=
LDAP_BIND_CREDENTIALS=
LDAP_SEARCH_BASE=

# File Upload Configuration
UPLOAD_MAX_SIZE=100MB
UPLOAD_ALLOWED_TYPES=csv,xlsx,json
UPLOAD_STORAGE=local

# AWS Configuration (Optional - for production scale)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=corporate-wellness-files

# Monitoring & Logging
LOG_LEVEL=info
LOG_FORMAT=json
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# Security Settings
BCRYPT_ROUNDS=12
JWT_EXPIRES_IN=24h
SESSION_EXPIRES_IN=86400000
MFA_ENABLED=true

# Feature Flags
BULK_ONBOARDING_ENABLED=true
ANALYTICS_ENABLED=true
WHITE_LABEL_ENABLED=true
ENTERPRISE_SSO_ENABLED=true

# Corporate App Integration URLs
FERTILITYTRACKER_URL=https://fertilitytracker.com
PREGNANCYCOMPANION_URL=https://pregnancycompanion.com
POSTPARTUMSUPPORT_URL=https://postpartumsupport.com
MENOWELLNESS_URL=https://www.phaseforward.app
SUPPORTPARTNER_URL=https://www.hotsupport.app
MYCONFIDANT_URL=https://myconfidant.com
SOBERPAL_URL=https://soberpal.com
INNERARCHITECT_URL=https://innerarchitect.com