{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/symptoms/(.*)",
      "dest": "/pages/api/symptoms/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/pages/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "@menowellness_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@menowellness_supabase_anon_key",
    "VITE_STRIPE_PUBLISHABLE_KEY": "@menowellness_stripe_publishable_key",
    "VITE_SENTIMENTASASERVICE_API_KEY": "@sentiment_api_key",
    "VITE_AWS_REGION": "@aws_region",
    "VITE_AWS_ACCESS_KEY_ID": "@aws_access_key_id",
    "VITE_AWS_SECRET_ACCESS_KEY": "@aws_secret_access_key"
  },
  "functions": {
    "pages/api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}